<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/back04"
    android:padding="20dp"
    tools:context=".activities.MainActivity">

    <ImageView
        android:id="@+id/iconIv"
        android:layout_width="200dp"
        android:layout_height="200dp"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="40dp"
        android:src="@drawable/logo01"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@+id/iconIv"
        android:layout_marginTop="10dp"
        android:text="Dobrodošli u svijet slatkih kolačića"
        android:textAlignment="center"
        android:fontFamily="@font/nunito_regular"
        android:textColor="@color/pink02"
        android:textSize="26sp"/>

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/loginBtn"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="10dp"
        android:background="@drawable/shape_button01"
        android:text="Prijava"
        android:textStyle="bold"
        android:fontFamily="@font/nunito_regular"
        android:layout_above="@+id/skipBtn"
        android:textColor="@color/white"/>

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/skipBtn"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:text="Nastavi bez prijave"
        android:textStyle="bold"
        android:fontFamily="@font/nunito_regular"
        android:textColor="@color/black"
        android:background="@drawable/shape_button02"/>

</RelativeLayout>